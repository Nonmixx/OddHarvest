# Server-side only: used by Vite dev proxy (vite-plugin-gemini-proxy) and by Vercel api/gemini.ts.
# On Vercel, add GOOGLE_API_KEY under Environment Variables (not exposed to the browser).
GOOGLE_API_KEY=your_google_ai_key
VITE_GOOGLE_GEMINI_MODEL=gemini-2.5-flash

# Enable database backend
VITE_USE_SUPABASE_BACKEND=false
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Reserved demo personas (must match supabase/seed.sql emails). Create these users in Supabase Auth, then sign in.
VITE_DEMO_FARMER_EMAIL=demo-farmer@oddharvest.demo
VITE_DEMO_BUYER_EMAIL=demo-buyer@oddharvest.demo
VITE_DEMO_DRIVER_EMAIL=demo-driver@oddharvest.demo